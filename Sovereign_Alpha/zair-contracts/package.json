{
    "name": "zair-contracts",
    "version": "1.0.0",
    "description": "Smart Contracts for Zair Protocol - Federated Risk Intelligence Network",
    "main": "index.js",
    "scripts": {
        "test": "hardhat test",
        "compile": "hardhat compile",
        "deploy": "hardhat run scripts/deploy.js",
        "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
        "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
        "deploy:arbitrum": "hardhat run scripts/deploy.js --network arbitrum",
        "verify": "hardhat verify",
        "coverage": "hardhat coverage",
        "gas-report": "REPORT_GAS=true hardhat test",
        "flatten": "hardhat flatten contracts/ZairProtocol.sol > build/ZairProtocol_flat.sol",
        "slither": "slither contracts/",
        "size": "hardhat size-contracts",
        "clean": "hardhat clean"
    },
    "keywords": [
        "zair",
        "rwa",
        "federated-learning",
        "depin",
        "consensus",
        "proof-of-alpha",
        "ethereum",
        "polygon",
        "arbitrum"
    ],
    "author": "Sovereign Alpha",
    "license": "MIT",
    "devDependencies": {
        "@nomiclabs/hardhat-ethers": "^2.2.3",
        "@nomiclabs/hardhat-etherscan": "^3.1.7",
        "@nomiclabs/hardhat-waffle": "^2.0.6",
        "@nomicfoundation/hardhat-chai-matchers": "^2.0.2",
        "@nomicfoundation/hardhat-toolbox": "^3.0.0",
        "@nomicfoundation/hardhat-verify": "^2.0.0",
        "@openzeppelin/contracts": "^5.0.0",
        "@openzeppelin/contracts-upgradeable": "^5.0.0",
        "@openzeppelin/hardhat-upgrades": "^2.0.0",
        "chai": "^4.3.7",
        "dotenv": "^16.3.1",
        "ethereum-waffle": "^4.0.10",
        "ethers": "^6.7.1",
        "hardhat": "^2.19.2",
        "hardhat-contract-sizer": "^2.10.0",
        "hardhat-gas-reporter": "^1.0.9",
        "prettier": "^3.1.0",
        "prettier-plugin-solidity": "^1.2.0",
        "solidity-coverage": "^0.8.5",
        "waffle": "^4.0.10"
    },
    "dependencies": {
        "axios": "^1.6.2",
        "web3": "^1.10.2"
    },
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    }
}